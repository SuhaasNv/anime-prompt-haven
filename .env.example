# Local dev database (docker compose up -d)
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/promptstar
DATABASE_PUBLIC_URL=postgresql://postgres:localdev@localhost:5432/promptstar

# ⚠️  PRODUCTION DATABASE — Use environment variable injection ONLY
# Never store credentials in this file. Set DATABASE_URL via:
#   - Railway platform env vars
#   - GitHub Actions secrets
#   - Deployment platform secrets manager

# OpenAI API Key for Listing Assistant
# Get your key from: https://platform.openai.com/account/api-keys
# NEVER commit the .env file with your actual key to git
OPENAI_API_KEY=your_openai_api_key_here

# Google SSO (optional — sign-in falls back to email/password if unset)
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/google/callback        (local dev)
#   https://<your-railway-domain>/api/auth/google/callback (production)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Public base URL of the app, used to build the OAuth redirect URI in production
# (so a spoofed Host header can't alter it). Leave unset locally to derive it
# from the request. Example: https://promptstar-app-production.up.railway.app
APP_BASE_URL=
